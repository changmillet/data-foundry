{
  "$schema": "schemas/capability-ownership-rules.schema.json",
  "schema_version": 1,
  "updated_at_utc": "2026-06-04T00:00:00Z",
  "principle": "Foundry owns routing, task state, manifests, reports, and policy checks. Reusable data logic belongs in the project that owns the schema, converter, CLI command, skill, runtime, database, or API surface.",
  "owners": [
    {
      "owner_project": "tiangong-lca-data-foundry",
      "owns": [
        "filesystem task queue",
        "capability route plans",
        "workspace manifests",
        "source package/document intake records",
        "artifact and policy checks",
        "profile-aware dataset curation package assembly",
        "gate aggregation"
      ],
      "does_not_own": [
        "TIDAS schema definitions",
        "source package converters",
        "dataset validation engines",
        "curation queue state machine",
        "remote write semantics",
        "shared skill workflows"
      ]
    },
    {
      "owner_project": "tidas-sdk",
      "owns": [
        "TIDAS JSON schemas",
        "TIDAS methodology YAML",
        "runtime rulesets",
        "SDK contract/context APIs"
      ]
    },
    {
      "owner_project": "tidas-tools",
      "owns": ["external LCA package parsing", "format detection", "TIDAS/ILCD conversion reports"]
    },
    {
      "owner_project": "tiangong-lca-cli",
      "owns": [
        "dataset contract/context CLI surface",
        "dataset import and source authoring commands",
        "dataset curation queue build/next/verify",
        "schema validation",
        "QA, reference, publish, and verification commands"
      ]
    },
    {
      "owner_project": "tiangong-lca-skills",
      "owns": [
        "agent-facing import workflows",
        "contract-context usage instructions",
        "CLI orchestration skills"
      ]
    },
    {
      "owner_project": "tiangong-ai/skills",
      "owns": [
        "external source-evidence research skills",
        "SCI literature retrieval workflow",
        "Tiangong KB search wrappers"
      ]
    }
  ],
  "decision_rules": [
    {
      "id": "schema-or-contract",
      "route_to": "tidas-sdk / tiangong-lca-cli",
      "use_when": [
        "AI needs full schema text, methodology YAML, runtime rulesets, or a stable context pack"
      ],
      "examples": ["dataset context-pack", "SDK getTidasContractPack"]
    },
    {
      "id": "source-package-conversion",
      "route_to": "tidas-tools / tiangong-lca-cli",
      "use_when": ["the input is a supported packaged LCA dataset"],
      "examples": ["dataset import-lca convert"]
    },
    {
      "id": "source-document-authoring",
      "route_to": "tiangong-lca-cli / tiangong-lca-skills",
      "use_when": ["the input is PDF, Excel, image, web export, screenshot, or free text"],
      "examples": ["dataset author", "$tidas-data-import"]
    },
    {
      "id": "external-source-evidence-skill",
      "route_to": "tiangong-ai/skills via npx skills runtime resolution",
      "use_when": [
        "the task needs fast-moving Tiangong AI document extraction or KB research workflows such as source-document fulltext extraction or SCI literature evidence retrieval"
      ],
      "examples": [
        "npx --yes skills@latest use https://github.com/tiangong-ai/skills --skill document-granular-decompose --full-depth",
        "npx --yes skills@latest use https://github.com/tiangong-ai/skills --skill tiangong-kb-sci-search --full-depth"
      ]
    },
    {
      "id": "foundry-routing",
      "route_to": "tiangong-lca-data-foundry",
      "use_when": [
        "the change only selects capabilities, records manifests, updates task state, or checks policy"
      ],
      "examples": ["route-task", "capability registry update", "dataset-curation-gate"]
    }
  ],
  "required_follow_up_fields": [
    "missing_capability",
    "owner_project",
    "input_contract",
    "output_contract",
    "verification_gate",
    "blocking_task"
  ]
}
