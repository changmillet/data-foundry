{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiangong-lca.local/foundry/mutation-plan.schema.json",
  "title": "Foundry State-Code-Aware Mutation Plan",
  "type": "object",
  "required": [
    "generated_at_utc",
    "task_id",
    "status",
    "remote_commit_allowed",
    "policy",
    "operation_counts",
    "mutations"
  ],
  "additionalProperties": true,
  "properties": {
    "generated_at_utc": { "type": "string" },
    "task_id": { "type": "string" },
    "status": { "type": "string" },
    "remote_commit_allowed": { "type": "boolean" },
    "policy": {
      "type": "object",
      "required": [
        "require_mutation_plan",
        "require_state_code_write_policy",
        "prefer_update_for_state_code_0",
        "require_insert_reason_for_versioned_write",
        "state_code_100_requires_source_review",
        "unknown_state_code_blocks_remote_write",
        "dry_run_before_remote_write"
      ],
      "additionalProperties": true
    },
    "operation_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "mutations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_type",
          "record_id",
          "account_or_dataset_scope",
          "current_state_code",
          "proposed_mutation_type",
          "fields_affected",
          "old_values",
          "new_values",
          "evidence_references",
          "reason",
          "expected_impact_on_reference_closure",
          "risk_level",
          "dry_run_status",
          "remote_commit_allowed",
          "gate_status"
        ],
        "additionalProperties": true,
        "properties": {
          "record_type": { "type": "string" },
          "record_id": { "type": "string" },
          "version": { "type": ["string", "null"] },
          "account_or_dataset_scope": { "type": "string" },
          "current_state_code": { "type": ["integer", "null"] },
          "proposed_mutation_type": {
            "type": "string",
            "enum": ["update", "insert", "skip", "manual-review", "follow-up"]
          },
          "preferred_write_if_approved": { "type": ["string", "null"] },
          "fields_affected": {
            "type": "array",
            "items": { "type": "string" }
          },
          "old_values": { "type": ["object", "array", "string", "number", "boolean", "null"] },
          "new_values": { "type": ["object", "array", "string", "number", "boolean", "null"] },
          "evidence_references": {
            "type": "array",
            "items": { "type": "string" }
          },
          "reason": { "type": "string" },
          "expected_impact_on_reference_closure": { "type": "string" },
          "risk_level": { "type": "string" },
          "dry_run_status": { "type": "string" },
          "remote_commit_allowed": { "type": "boolean" },
          "gate_status": { "type": "object" }
        }
      }
    }
  }
}
