{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiangong-lca.local/foundry/artifact-check-report.schema.json",
  "title": "Foundry Artifact Check Report",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at_utc",
    "contract_path",
    "status",
    "checks",
    "continuation_prompt"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "generated_at_utc": { "type": "string" },
    "contract_path": { "type": "string" },
    "task_id": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["passed", "failed"] },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "passed", "severity", "summary", "score"],
        "additionalProperties": true,
        "properties": {
          "check": { "type": "string" },
          "passed": { "type": "boolean" },
          "severity": { "type": "string", "enum": ["info", "warning", "error"] },
          "summary": { "type": "string" },
          "score": { "type": "number" },
          "reasons": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      }
    },
    "continuation_prompt": { "type": "string" }
  }
}
