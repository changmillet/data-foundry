{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiangong-lca.local/foundry/gate-index.schema.json",
  "title": "Foundry Gate Index",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at_utc",
    "task_id",
    "run_kind",
    "status",
    "counts",
    "gates"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "generated_at_utc": { "type": "string" },
    "task_id": { "type": "string" },
    "run_kind": { "type": "string" },
    "status": { "type": "string", "enum": ["passed", "blocked"] },
    "source_report_status": { "type": "string" },
    "workspace": { "type": "string" },
    "capability_registry": { "type": "string" },
    "counts": {
      "type": "object",
      "required": ["gates", "blocking_gates", "command_failures"],
      "additionalProperties": true,
      "properties": {
        "gates": { "type": "integer", "minimum": 0 },
        "blocking_gates": { "type": "integer", "minimum": 0 },
        "command_failures": { "type": "integer", "minimum": 0 }
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capability_id", "status", "blocking"],
        "additionalProperties": true,
        "properties": {
          "task_id": { "type": "string" },
          "run_kind": { "type": "string" },
          "sample_id": { "type": ["string", "null"] },
          "dataset_kind": { "type": ["string", "null"] },
          "capability_id": { "type": "string" },
          "class": { "type": ["string", "null"] },
          "owner_project": { "type": ["string", "null"] },
          "entrypoint": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "blocking": { "type": "boolean" },
          "next_action": { "type": ["string", "null"] },
          "blockers": { "type": "array" },
          "quality_gaps": { "type": "array" },
          "artifacts": { "type": "object" }
        }
      }
    }
  }
}
