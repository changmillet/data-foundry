{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiangong-lca.local/foundry/post-write-verification.schema.json",
  "title": "Foundry Post-Write Verification Report",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at_utc",
    "task_id",
    "run_kind",
    "status",
    "source_target_report",
    "source_mutation_plan_handoff",
    "counts",
    "samples"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "generated_at_utc": { "type": "string" },
    "task_id": { "type": "string" },
    "run_kind": { "type": "string", "const": "post-write-verify" },
    "status": {
      "type": "string",
      "enum": [
        "passed_post_write_verification",
        "blocked_post_write_verification",
        "no_publish_ready_entries"
      ]
    },
    "source_target_report": { "type": "string" },
    "source_mutation_plan_handoff": { "type": "string" },
    "edge_verify": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mode", "url_configured", "jwt_configured"],
      "properties": {
        "mode": { "type": "string" },
        "url_configured": { "type": "boolean" },
        "jwt_configured": { "type": "boolean" }
      }
    },
    "counts": {
      "type": "object",
      "required": ["samples", "publish_ready_entries", "command_failures", "blockers"],
      "additionalProperties": true,
      "properties": {
        "samples": { "type": "integer", "minimum": 0 },
        "publish_ready_entries": { "type": "integer", "minimum": 0 },
        "command_failures": { "type": "integer", "minimum": 0 },
        "blockers": { "type": "integer", "minimum": 0 }
      }
    },
    "samples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sample_id", "status", "process", "flow"],
        "additionalProperties": true,
        "properties": {
          "sample_id": { "type": "string" },
          "status": { "type": "string" },
          "command_failure_count": { "type": "integer", "minimum": 0 },
          "blocker_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "files": { "type": "object" }
  }
}
