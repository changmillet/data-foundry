{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiangong-lca.local/foundry/capability-route-plan.schema.json",
  "title": "Foundry Capability Route Plan",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at_utc",
    "task",
    "status",
    "capability_registry",
    "counts",
    "routes",
    "selected_capabilities",
    "missing_capabilities",
    "adapter_workspace_plan"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "generated_at_utc": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["routed", "missing_capabilities", "no_route"]
    },
    "next_action": { "type": "string" },
    "capability_registry": { "type": "string" },
    "task": {
      "type": "object",
      "required": ["id", "kind"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "category": { "type": ["string", "null"] },
        "source_task_path": { "type": ["string", "null"] },
        "dataset_type": { "type": "string" },
        "repo_owner": { "type": ["string", "null"] },
        "required_gates": { "type": "array", "items": { "type": "string" } }
      }
    },
    "counts": {
      "type": "object",
      "required": ["required_classes", "selected_capabilities", "missing_capabilities"],
      "additionalProperties": true,
      "properties": {
        "required_classes": { "type": "integer", "minimum": 0 },
        "selected_capabilities": { "type": "integer", "minimum": 0 },
        "missing_capabilities": { "type": "integer", "minimum": 0 }
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["class", "status", "capability_ids"],
        "additionalProperties": true,
        "properties": {
          "class": { "type": "string" },
          "status": { "type": "string" },
          "capability_ids": { "type": "array", "items": { "type": "string" } },
          "owner_projects": { "type": "array", "items": { "type": "string" } },
          "missing_owner_project": { "type": ["string", "null"] }
        }
      }
    },
    "missing_capabilities": { "type": "array" },
    "adapter_workspace_plan": { "type": "array" },
    "selected_capabilities": { "type": "array" }
  }
}
