{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiangong-lca.local/foundry/completeness-snapshot.schema.json",
  "title": "Foundry Completeness Snapshot",
  "type": "object",
  "required": [
    "generated_at_utc",
    "task_id",
    "status",
    "metrics",
    "matrix_readiness_status",
    "compute_validation_status",
    "blockers",
    "generated_follow_up_tasks"
  ],
  "additionalProperties": true,
  "properties": {
    "generated_at_utc": { "type": "string" },
    "task_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["passed", "blocked", "partial", "failed"]
    },
    "reason": { "type": ["string", "null"] },
    "metrics": {
      "type": "object",
      "required": [
        "total_processes",
        "total_exchanges",
        "distinct_exchange_flows",
        "reference_closure_target_exchanges",
        "exchange_flows_covered_by_reference_flow_process",
        "elementary_exchange_flows_excluded_from_reference_closure",
        "missing_reference_flow_processes",
        "exchange_flow_metadata_missing",
        "ambiguous_flow_matches",
        "missing_or_duplicate_flows",
        "unresolved_mean_value_evidence",
        "unresolved_unit_dimension_mismatches",
        "state_code_0_records_updated_or_proposed",
        "state_code_100_records_requiring_source_review"
      ],
      "additionalProperties": true,
      "properties": {
        "total_processes": { "type": ["integer", "null"], "minimum": 0 },
        "total_exchanges": { "type": ["integer", "null"], "minimum": 0 },
        "distinct_exchange_flows": { "type": ["integer", "null"], "minimum": 0 },
        "reference_closure_target_exchanges": { "type": ["integer", "null"], "minimum": 0 },
        "exchange_flows_covered_by_reference_flow_process": { "type": ["integer", "null"], "minimum": 0 },
        "elementary_exchange_flows_excluded_from_reference_closure": { "type": ["integer", "null"], "minimum": 0 },
        "missing_reference_flow_processes": { "type": ["integer", "null"], "minimum": 0 },
        "exchange_flow_metadata_missing": { "type": ["integer", "null"], "minimum": 0 },
        "ambiguous_flow_matches": { "type": ["integer", "null"], "minimum": 0 },
        "missing_or_duplicate_flows": { "type": ["integer", "null"], "minimum": 0 },
        "unresolved_mean_value_evidence": { "type": ["integer", "null"], "minimum": 0 },
        "unresolved_unit_dimension_mismatches": { "type": ["integer", "null"], "minimum": 0 },
        "state_code_0_records_updated_or_proposed": { "type": ["integer", "null"], "minimum": 0 },
        "state_code_100_records_requiring_source_review": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "matrix_readiness_status": {
      "type": "string",
      "enum": ["ready", "blocked", "not_run", "failed"]
    },
    "compute_validation_status": {
      "type": "string",
      "enum": ["passed", "blocked", "not_run", "failed"]
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "generated_follow_up_tasks": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
