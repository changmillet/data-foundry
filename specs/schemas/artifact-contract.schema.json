{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiangong-lca.local/foundry/artifact-contract.schema.json",
  "title": "Foundry Artifact Acceptance Contract",
  "type": "object",
  "required": ["id", "description", "artifacts", "checks"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "description": { "type": "string" },
    "workspace": { "type": "string" },
    "trace": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "type": { "type": "string" },
          "required": { "type": "boolean" },
          "min_bytes": { "type": "integer", "minimum": 0 },
          "tracked": { "type": "boolean" }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string" },
          "severity": { "type": "string", "enum": ["info", "warning", "error"] },
          "config": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "assertions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["file", "path"],
                  "additionalProperties": true,
                  "properties": {
                    "name": { "type": "string" },
                    "file": { "type": "string" },
                    "path": { "type": "string" },
                    "operator": {
                      "type": "string",
                      "enum": ["exists", "not_empty", "equals", "not_equals", "min", "max", "includes"]
                    },
                    "expected": {},
                    "suggestion": { "type": "string" },
                    "requires_user_input": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
