{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiangong-lca.dev/schemas/automated-lca-golden-fixtures.schema.json",
  "title": "Automated LCA Golden Fixture Matrix",
  "type": "object",
  "required": ["schema_version", "required_coverage_classes", "fixtures"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "updated_at_utc": { "type": "string" },
    "purpose": { "type": "string" },
    "required_coverage_classes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "coverage_classes", "source"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "coverage_classes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1,
            "uniqueItems": true
          },
          "source": {
            "enum": [
              "sample-scenarios-dry-run",
              "target-datasets-gate-run",
              "post-write-verify",
              "matrix-readiness-verify",
              "compute-repair-probe"
            ]
          },
          "runtime_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["report", "path"],
              "properties": {
                "report": {
                  "enum": ["sample_scenarios", "target_datasets", "post_write", "compute_repair", "matrix_readiness"]
                },
                "sample_id": { "type": "string" },
                "path": { "type": "string", "minLength": 1 },
                "equals": {},
                "includes": {
                  "type": "array",
                  "items": {}
                },
                "min": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
