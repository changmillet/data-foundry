# Foundry-local Tiangong Wiki workspace.
# Run commands from the repository root, or pass --env-file wiki/.wiki.env.

WIKI_PATH=/home/example/projects/workspace/tiangong-lca-data-foundry/wiki/pages
VAULT_PATH=/home/example/projects/workspace/tiangong-lca-data-foundry/wiki/vault
VAULT_SOURCE=local
VAULT_HASH_MODE=content
WIKI_DB_PATH=/home/example/projects/workspace/tiangong-lca-data-foundry/wiki/index.db
WIKI_CONFIG_PATH=/home/example/projects/workspace/tiangong-lca-data-foundry/wiki/wiki.config.json
WIKI_TEMPLATES_PATH=/home/example/projects/workspace/tiangong-lca-data-foundry/wiki/templates
WIKI_SYNC_INTERVAL=86400
WIKI_AGENT_ENABLED=false
WIKI_PARSER_SKILLS=document-granular-decompose
