# Tracker adapters
LINEAR_API_KEY=
GITHUB_TOKEN=

# Runtime
FOUNDRY_WORKSPACE_ROOT=.foundry/workspaces
FOUNDRY_LOG_ROOT=.foundry/logs
LCA_DATA_AGENT_ROOT=/home/example/projects/LCA-DATA-AGENT
LCA_DATA_AGENT_ENV_FILE=/home/example/projects/LCA-DATA-AGENT/.env

# Remote write gates. Keep false until a single-record smoke test is explicitly approved.
FOUNDRY_ENABLE_REMOTE_COMMIT=false
FOUNDRY_SINGLE_RECORD_COMMIT=false
FOUNDRY_REMOTE_COMMIT_LIMIT=1

# Optional source repo used by workspace hooks
SOURCE_REPO_URL=git@github.com:tiangong-lca/data-foundry.git
