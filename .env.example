# Tracker adapters
LINEAR_API_KEY=
GITHUB_TOKEN=

# Runtime
FOUNDRY_WORKSPACE_ROOT=.foundry/workspaces
FOUNDRY_LOG_ROOT=.foundry/logs
FOUNDRY_PROJECTS_ROOT=/home/example/projects
FOUNDRY_LCA_WORKSPACE_ROOT=/home/example/projects/workspace
LCA_DATA_AGENT_ROOT=/home/example/projects/LCA-DATA-AGENT
LCA_DATA_AGENT_ENV_FILE=/home/example/projects/LCA-DATA-AGENT/.env
TIANGONG_LCA_CLI_DIR=/home/example/projects/workspace/tiangong-lca-cli
TIANGONG_LCA_SKILLS_ROOT=/home/example/projects/workspace/tiangong-lca-skills
LCA_SKILLS_ROOT=/home/example/projects/lca-skills
FOUNDRY_AGENT_SKILLS_ROOT=/home/example/.agents/skills

# TianGong CLI / skill authentication.
# Foundry scripts load LCA_DATA_AGENT_ENV_FILE automatically, so the preferred
# local setup is to keep real secrets in /home/example/projects/LCA-DATA-AGENT/.env.
# If you run `tiangong` or a skill directly from this repository, export the
# real values or copy them from that env file into local `.env`.
#
# Required for API-backed CLI/skill commands:
# TIANGONG_LCA_API_BASE_URL=
# TIANGONG_LCA_API_KEY=REPLACE_ME
# TIANGONG_LCA_SUPABASE_PUBLISHABLE_KEY=REPLACE_ME
# TIANGONG_LCA_REGION=us-east-1
#
# Optional session control:
# TIANGONG_LCA_SESSION_FILE=.foundry/state/tiangong-lca-session.json
# TIANGONG_LCA_DISABLE_SESSION_CACHE=false
# TIANGONG_LCA_FORCE_REAUTH=false
#
# Optional, only for review commands with --enable-llm:
# TIANGONG_LCA_REVIEW_LLM_BASE_URL=
# TIANGONG_LCA_REVIEW_LLM_API_KEY=REPLACE_ME
# TIANGONG_LCA_REVIEW_LLM_MODEL=

# Remote write gates. Keep false until a single-record smoke test is explicitly approved.
FOUNDRY_ENABLE_REMOTE_COMMIT=false
FOUNDRY_SINGLE_RECORD_COMMIT=false
FOUNDRY_REMOTE_COMMIT_LIMIT=1

# Optional source repo used by workspace hooks
SOURCE_REPO_URL=git@github.com:tiangong-lca/data-foundry.git
