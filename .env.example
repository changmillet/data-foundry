# TianGong LCA Data Foundry runtime environment.
# Keep this file free of real credentials. Before adding new variables, check
# docs/env-surface-policy.md and run `npm run env:check`.

# ---------------------------------------------------------------------------
# 1. Current-user TianGong LCA account
# ---------------------------------------------------------------------------
# Required for CLI-backed remote readback, dry-run, save-draft/publish handoff,
# and $dataset-rls-maintenance current-user RLS planning. The CLI decodes
# `TIANGONG_LCA_API_KEY` as a user API key bootstrap, exchanges it for a user
# session, caches the session locally, and uses the resolved access token for
# runtime requests. No generic `SUPABASE_URL` / `SUPABASE_KEY` env is needed.
#
# Accepted values for `TIANGONG_LCA_API_BASE_URL`:
# - https://<project>.supabase.co
# - https://<project>.supabase.co/functions/v1
# - https://<project>.supabase.co/rest/v1

TIANGONG_LCA_API_BASE_URL=https://qgzvkongdjqiiamzbbts.supabase.co/functions/v1
TIANGONG_LCA_API_KEY=
TIANGONG_LCA_REGION=us-east-1
TIANGONG_LCA_SUPABASE_PUBLISHABLE_KEY=sb_publishable_EFWH4E61tpAtf82WQ37xTA_Fxa5OPyg
TIANGONG_LCA_SESSION_FILE=
TIANGONG_LCA_DISABLE_SESSION_CACHE=false
TIANGONG_LCA_FORCE_REAUTH=false

# Optional, non-secret display label for the credentials currently loaded.
# This is for human orientation only. Agents must treat the resolved API key,
# session, current-user snapshot, and frozen manifests as authoritative.
FOUNDRY_ACCOUNT_LABEL=
FOUNDRY_ACCOUNT_LABEL_REQUIRED_FOR_HUMANS=false

# ---------------------------------------------------------------------------
# 2. Local project and skill paths
# ---------------------------------------------------------------------------
# Usually blank. Set only for explicit local test binaries or installed skill roots.

FOUNDRY_WORKSPACE_ROOT=.foundry/workspaces
FOUNDRY_LOG_ROOT=.foundry/logs
FOUNDRY_LCA_WORKSPACE_ROOT=
TIANGONG_LCA_CLI_BIN=
TIANGONG_LCA_SKILLS_ROOT=
FOUNDRY_AGENT_SKILLS_ROOT=.agents/skills

# ---------------------------------------------------------------------------
# 3. Shared runtime skills: Tiangong AI evidence tools
# ---------------------------------------------------------------------------
# Used by .agents/skills/tiangong-kb-sci-search. The wrapper defaults to
# `npx @tiangong-ai/cli@latest`; set CLI overrides only for local development.
# `TIANGONG_AI_APIKEY` is the env name accepted by @tiangong-ai/cli.

TIANGONG_AI_API_BASE_URL=
TIANGONG_AI_APIKEY=
TIANGONG_AI_CLI=
TIANGONG_AI_CLI_BIN=

# LCA CLI evidence-search helpers. These are distinct from the external
# tiangong-ai SCI skill above and remain under the TianGong LCA env contract.

TIANGONG_LCA_KB_SEARCH_API_BASE_URL=
TIANGONG_LCA_KB_SEARCH_API_KEY=
TIANGONG_LCA_KB_SEARCH_REGION=us-east-1

# ---------------------------------------------------------------------------
# 4. Document extraction / MinerU
# ---------------------------------------------------------------------------
# `tiangong-lca-cli dataset author` uses the TIANGONG_LCA_UNSTRUCTURED_* names.
# Runtime-installed $document-granular-decompose reads the UNSTRUCTURED_* aliases.
# Keep both families in sync in local .env when using document extraction.

TIANGONG_LCA_UNSTRUCTURED_API_BASE_URL=
TIANGONG_LCA_UNSTRUCTURED_API_KEY=
TIANGONG_LCA_UNSTRUCTURED_PROVIDER=
TIANGONG_LCA_UNSTRUCTURED_MODEL=
TIANGONG_LCA_UNSTRUCTURED_CHUNK_TYPE=false
TIANGONG_LCA_UNSTRUCTURED_RETURN_TXT=true

UNSTRUCTURED_API_BASE_URL=
UNSTRUCTURED_AUTH_TOKEN=
UNSTRUCTURED_PROVIDER=
UNSTRUCTURED_MODEL=

# ---------------------------------------------------------------------------
# 5. Optional QA review LLM
# ---------------------------------------------------------------------------
# Ignore this block unless `tiangong-lca qa process` or `tiangong-lca qa flow`
# is called with `--enable-llm`. When enabled, point the base URL at an
# OpenAI-compatible Responses API base URL. The CLI calls `<base_url>/responses`.

TIANGONG_LCA_REVIEW_LLM_BASE_URL=
TIANGONG_LCA_REVIEW_LLM_API_KEY=
TIANGONG_LCA_REVIEW_LLM_MODEL=

# ---------------------------------------------------------------------------
# 6. Foundry write safety gates
# ---------------------------------------------------------------------------
# Keep remote commit gates false unless a task explicitly permits a bounded
# smoke commit and all dry-run / verification gates pass. $dataset-rls-maintenance
# must still require an explicit maintenance plan and approval before apply.

FOUNDRY_ENABLE_REMOTE_COMMIT=false
FOUNDRY_SINGLE_RECORD_COMMIT=false
FOUNDRY_REMOTE_COMMIT_LIMIT=1

# Intentionally absent:
# - `SUPABASE_URL` / `SUPABASE_KEY`
#   The public env contract stays under `TIANGONG_LCA_API_*`; the CLI derives
#   the native `@supabase/supabase-js` client from those keys.
# - `TIANGONG_LCA_TIDAS_SDK_DIR`
#   The CLI now loads `@tiangong-lca/tidas-sdk` directly from package
#   dependencies instead of resolving a sibling checkout or CI-injected dist.
