{
  "name": "tiangong-lca-data-foundry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Private Symphony-style orchestration project for autonomous TianGong LCA data work.",
  "scripts": {
    "init:runtime": "node scripts/foundry.mjs init",
    "doctor": "node scripts/foundry.mjs doctor",
    "workspace:map": "node scripts/foundry.mjs workspace-map",
    "capabilities:list": "node scripts/foundry.mjs capabilities-list",
    "task:route": "node scripts/foundry.mjs route-task",
    "env:check": "node scripts/foundry.mjs env-check",
    "account-wide:audit": "node scripts/foundry.mjs account-wide-audit-run",
    "account:run": "node scripts/with-lca-account.mjs",
    "workflow:check": "node scripts/foundry.mjs workflow-check",
    "storage:check": "node scripts/foundry.mjs storage-check",
    "acceptance:check": "node scripts/foundry.mjs acceptance-check",
    "wiki:build-rulesbook": "python3 scripts/build-rulesbook-wiki.py",
    "wiki:doctor": "npx @biaoo/tiangong-wiki@0.3.13 doctor --env-file wiki/.wiki.env",
    "wiki:init": "npx @biaoo/tiangong-wiki@0.3.13 init --env-file wiki/.wiki.env",
    "wiki:sync": "npx @biaoo/tiangong-wiki@0.3.13 sync --env-file wiki/.wiki.env",
    "wiki:list": "npx @biaoo/tiangong-wiki@0.3.13 list --env-file wiki/.wiki.env --type source-summary --limit 20",
    "wiki:stat": "npx @biaoo/tiangong-wiki@0.3.13 stat --env-file wiki/.wiki.env",
    "wiki:fts": "npx @biaoo/tiangong-wiki@0.3.13 fts --env-file wiki/.wiki.env --limit 3",
    "orchestrator:once": "node scripts/foundry.mjs orchestrate --once",
    "orchestrator:rerun-review": "node scripts/foundry.mjs orchestrate --once --include-review",
    "compute-repair:probe": "node scripts/foundry.mjs compute-repair-probe --task-id lca-compute-task-2026-05-10-factorization-not-prepared-singular",
    "compute-repair:artifacts:check": "node scripts/foundry.mjs artifact-contract-check --contract specs/acceptance/lca-compute-repair-20260510.artifacts.json",
    "compute-repair:rerun": "node scripts/foundry.mjs orchestrate --once --include-review --task-id lca-compute-task-2026-05-10-factorization-not-prepared-singular",
    "sample-scenarios:dry-run": "node scripts/foundry.mjs sample-scenarios-dry-run",
    "target-datasets:gate-run": "node scripts/foundry.mjs target-datasets-gate-run",
    "post-write:verify": "node scripts/foundry.mjs post-write-verify",
    "matrix-readiness:verify": "node scripts/foundry.mjs matrix-readiness-verify",
    "golden-fixtures:check": "node scripts/foundry.mjs golden-fixtures-check",
    "orchestrator:run": "node scripts/foundry.mjs orchestrate",
    "orchestrator:status": "node scripts/foundry.mjs status",
    "tasks:list": "node scripts/foundry.mjs tasks-list",
    "tasks:check": "node scripts/foundry.mjs tasks-check"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "UNLICENSED"
}
