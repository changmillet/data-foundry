{
  "name": "tiangong-lca-data-foundry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Control plane for TianGong LCA external dataset import and TIDAS authoring work.",
  "scripts": {
    "init:runtime": "node scripts/foundry.mjs init",
    "doctor": "node scripts/foundry.mjs doctor",
    "workspace:map": "node scripts/foundry.mjs workspace-map",
    "capabilities:list": "node scripts/foundry.mjs capabilities-list",
    "profiles:list": "node scripts/foundry.mjs profiles-list",
    "task:route": "node scripts/foundry.mjs route-task",
    "task:run": "node scripts/foundry.mjs route-task",
    "task:status": "node scripts/foundry.mjs tasks-check",
    "env:check": "node scripts/foundry.mjs env-check",
    "account:run": "node scripts/with-lca-account.mjs",
    "workflow:check": "node scripts/foundry.mjs workflow-check",
    "storage:check": "node scripts/foundry.mjs storage-check",
    "acceptance:check": "node scripts/foundry.mjs acceptance-check",
    "skills:list": "npx --yes skills@latest list --json",
    "skills:update": "npx --yes skills@latest update --project --yes",
    "skills:source-evidence:list": "npx --yes skills@latest add https://github.com/tiangong-ai/skills --list --full-depth",
    "skills:source-evidence:use:sci": "npx --yes skills@latest use https://github.com/tiangong-ai/skills --skill tiangong-kb-sci-search --full-depth",
    "skills:source-evidence:install:sci": "npx --yes skills@latest add https://github.com/tiangong-ai/skills --skill tiangong-kb-sci-search --agent '*' --yes --full-depth",
    "test:full-context-gate": "node --test test/full-context-gate.test.mjs",
    "tasks:list": "node scripts/foundry.mjs tasks-list",
    "tasks:check": "node scripts/foundry.mjs tasks-check",
    "task:complete": "node scripts/foundry.mjs task-complete"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "UNLICENSED"
}
